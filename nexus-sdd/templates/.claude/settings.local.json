{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(chmod +x *)",
      "Bash(gh auth *)",
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(rm -rf .git)",
      "Bash(git init *)",
      "Bash(gh repo *)",
      "Bash(git *)",
      "Bash(mkdir -p *)",
      "Read(//tmp/**)",
      "Read(//Users/jesus/**)",
      "Bash(pip3 install *)",
      "Bash(pip list *)",
      "Bash(go build *)",
      "Bash(go mod *)",
      "Bash(go test *)",
      "Bash(go version *)",
      "Bash(brew install *)",
      "Bash(mnemo *)",
      "Bash(EMBEDDER_MOCK=true *)",
      "Bash(nexus-sdd *)",
      "Bash(cp *)",
      "Bash(sudo cp *)",
      "Bash(uv tool *)",
      "Bash(ollama list *)",
      "Bash(claude --version)",
      "Bash(claude update *)",
      "Bash(graphify *)",
      "Bash(python3 -c *)",
      "Bash(PYTHONPATH=*)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
